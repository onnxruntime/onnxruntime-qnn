+std::string TensorShapeToString(std::vector<int64_t> shape) {
+  std::string result;
+
+  result.append("{");
+  bool first = true;
+  for (auto dim : shape) {
+    if (!first) {
+      result.append(",");
+    }
+
+    result.append(std::to_string(dim));
+    first = false;
+  }
+  result.append("}");
+
+  return result;
