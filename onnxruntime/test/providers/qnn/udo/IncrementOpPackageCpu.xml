<?xml version="1.0" encoding="UTF-8"?>
<OpDefCollection
        PackageName="IncrementOpPackage"
        Domain="example"
        Version="1.0"
>
    <OpDefList>
        <!--Example Op Package which shows how a package can be defined using supplemental info-->
        <OpDef>
            <Name>Increment</Name>
            <Description>
                <Content>
                    An UDO that add constant to input for demo
                </Content>
            </Description>
            <Input>
                <Name>in[0]</Name>
                <Description>
                    <Content>input</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
                <Shape>
                    <Rank>ND</Rank>
                </Shape>
            </Input>

            <Output>
                <Name>out[0]</Name>
                <Description>
                    <Content>output</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
                <Shape>
                    <Rank>ND</Rank>
                </Shape>
            </Output>

            <Parameter>
                <Name>constant</Name>
                <Mandatory>false</Mandatory>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
                <Shape>
                    <Rank>SCALAR</Rank>
                </Shape>
                <Default>1.0</Default>
            </Parameter>

            <!--This Op is implemented on these Backends-->
            <SupportedBackend>CPU</SupportedBackend>
        </OpDef>
    </OpDefList>

</OpDefCollection>
